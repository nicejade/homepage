---
import configs from '../configs';
---

<section id="page-nav">
	{
		configs.map(({ title }) => (
			<a
				title={title}
				href={`#${title}`}
				class="nav-link py-2 px-5 me-3 mb-3 font-medium focus:outline-none rounded-full border border-gray-200 hover:bg-gray-100 focus:z-10 focus:ring-0 md:px-4 md:py-1.5 md:me-2"
				data-nav-title={title}
				data-nav-path={`#${title}`}
			>
				{title}
			</a>
		))
	}
</section>

<style>
	#page-nav {
		display: flex;
		flex-direction: row;
		justify-content: center;
		flex-wrap: wrap;
		margin: 2rem 0;
	}

	.nav-link {
		color: var(--sl-color-text-accent);
		margin: 0.5rem;
	}

	.nav-link:hover {
		cursor: pointer;
		animation: jelly 0.5s;
		color: #ff6f61;
	}

	@keyframes jelly {
		0%,
		100% {
			transform: scale(1, 1);
		}
		25% {
			transform: scale(0.9, 1.1);
		}
		50% {
			transform: scale(1.1, 0.9);
		}
		75% {
			transform: scale(0.95, 1.05);
		}
	}
</style>

<script>
	declare global {
		interface Window {
			gtag?: (...args: unknown[]) => void;
		}
	}

	document.getElementById('page-nav')?.addEventListener('click', (event) => {
		const link = (event.target as Element | null)?.closest<HTMLAnchorElement>('a[data-nav-path]');
		if (!link) return;

		window.gtag?.('event', 'navigation_click', {
			navigation_path: link.dataset.navPath,
			navigation_title: link.dataset.navTitle,
		});
	});
</script>
