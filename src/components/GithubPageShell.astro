---
type Props = {
	wide?: boolean;
	/** When true, omit `not-content` so Starlight markdown styles apply (e.g. MDX body). */
	markdown?: boolean;
	class?: string;
};

const { wide = true, markdown = false, class: className = '' } = Astro.props;
const widthClass = wide ? 'max-w-6xl' : 'max-w-3xl';
const contentClass = markdown ? '' : 'not-content';
---

<div class={`${contentClass} mx-auto w-full px-4 sm:px-6 ${widthClass} ${className}`}>
	<slot />
</div>
