---
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';
import { getCollection } from 'astro:content';
import GithubPageShell from '../../components/GithubPageShell.astro';
import GithubProjectExplorer from '../../components/GithubProjectExplorer.svelte';
import { normalizeGithubProject, sortGithubProjects } from '../../lib/github-curation';

const entries = await getCollection('github');
const projects = sortGithubProjects(
	entries.map((entry) => normalizeGithubProject({ slug: entry.slug, data: entry.data })),
);

const description = '收录 AI 编程、本地模型、工作流自动化与开发者生产力方向的高质量 GitHub 开源项目。';
---

<StarlightPage
	hasSidebar={false}
	frontmatter={{
		title: '开源琅嬛阁',
		description,
		tableOfContents: false,
		head: [
			{ tag: 'link', attrs: { rel: 'canonical', href: 'https://www.niceshare.site/github/' } },
			{ tag: 'meta', attrs: { property: 'og:title', content: '开源琅嬛阁 | 逍遥自在轩' } },
			{ tag: 'meta', attrs: { property: 'og:description', content: description } },
		],
	}}
>
	<GithubPageShell>
		<GithubProjectExplorer client:load projects={projects} />
	</GithubPageShell>
</StarlightPage>
